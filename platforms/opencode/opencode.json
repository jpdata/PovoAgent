{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md",
        "conventions.md",
        "PROJECT_CACHE.md"
    ],
    "mcp": {
        "fetch": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-fetch"
            ]
        },
        "github": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "environment": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "sequential-thinking": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        }
    }
}