{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md",
        "conventions.md"
    ],
    "mcp": {
        "fetch": {
            "type": "local",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-fetch"
            ]
        },
        "github": {
            "type": "local",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "sequential-thinking": {
            "type": "local",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        }
    }
}